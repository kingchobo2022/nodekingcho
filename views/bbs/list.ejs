<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <%= title %>
    </h2>
    <a href="/bbs/write?code=<%= code %>" class="btn btn-primary">글쓰기</a>
</div>

<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>번호</th>
            <th>제목</th>
            <th>작성자</th>
            <th>작성일</th>
        </tr>
    </thead>
    <tbody>
        <% if (posts.length > 0) { %>
            <% posts.forEach(post => {  %>
        <tr style="cursor: pointer;" onclick="location.href='#'">
            <td>
                <%= post.id %>
            </td>
            <td><a href="/bbs/view/<%= post.id %>" class="text-decoration-none text-dark fw-bold">
                    <%= post.subject %>
                </a></td>
            <td>
                <%= post.author_name || '탈퇴한 회원' %>
            </td>
            <td>
                <% 
  const d = new Date(post.created_at);
  const f = (unit) => new Intl.DateTimeFormat('ko-KR', { [unit]: '2-digit' }).format(d).replace('.', '');
  const year = d.getFullYear();
  const month = f('month');
  const day = f('day');
  const time = d.toTimeString().split(' ')[0];
%>
<%= `${year} ${month} ${day} ${time}` %>

            </td>
        </tr>
            <% }); %>
        <% } else { %>
        <tr>
            <td colspan="4" class="text-center py-5 text-muted">등록된 게시물이 없습니다.</td>
        </tr>    
        <% } %>    
    </tbody>
</table>

<!-- Pagination -->
<% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item <%= locals.currentPage === 1 ? 'disabled' : '' %>">
                <a class="page-link"
                    href="/bbs/list?code=<%= code %>&page=<%= locals.currentPage - 1 %>&search=<%= locals.search %>&searchType=<%= locals.searchType %>">이전</a>
            </li>
            <% for(let i=1; i <=totalPages; i++) { %>
                <li class="page-item <%= locals.currentPage === i ? 'active' : '' %>">
                    <a class="page-link"
                        href="/bbs/list?code=<%= code %>&page=<%= i %>&search=<%= locals.search %>&searchType=<%= locals.searchType %>">
                        <%= i %>
                    </a>
                </li>
                <% } %>
                    <li class="page-item <%= locals.currentPage === totalPages ? 'disabled' : '' %>">
                        <a class="page-link"
                            href="/bbs/list?code=<%= code %>&page=<%= locals.currentPage + 1 %>&search=<%= locals.search %>&searchType=<%= locals.searchType %>">다음</a>
                    </li>
        </ul>
    </nav>
<% } %>



<!-- Search Form -->
<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <form action="/bbs/list" method="get" class="d-flex gap-2" onsubmit="return validateSearch(this)">
            <input type="hidden" name="code" value="<%= code %>">
            <select name="searchType" class="form-select" style="width: 120px;">
                <option value="subject" <%=searchType==='subject' ? 'selected' : '' %>>제목</option>
                <option value="content" <%=searchType==='content' ? 'selected' : '' %>>내용</option>
                <option value="all" <%=searchType==='all' ? 'selected' : '' %>>제목+내용</option>
            </select>
            <input type="text" name="search" class="form-control" placeholder="검색어를 입력하세요"
                value="<%= search %>">
            <button type="submit" class="btn btn-secondary" style="width: 80px;">검색</button>
        </form>
    </div>

    <script>
        function validateSearch(form) {
            const search = form.search.value.trim();
            if (search === '') {
                alert('검색어를 입력해 주세요.');
                form.search.focus();
                return false;
            }
            return true;
        }
    </script>
</div>