<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Summernote CSS -->
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <!-- jQuery and Bootstrap JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Summernote JS -->
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">왕초뮤니티</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/intro">커뮤니티소개</a></li>
                    <li class="nav-item"><a class="nav-link" href="/member/benefits">커뮤니티 혜택</a></li>
                    <li class="nav-item"><a class="nav-link" href="/bbs/list?code=NOTICE">공지사항</a></li>
                    <li class="nav-item"><a class="nav-link" href="/bbs/list?code=FREE">자유게시판</a></li>
                </ul>
                <ul class="navbar-nav">
                    <% if (user) { %>
                    <li class="nav-item">
                        <span class="nav-link text-white">
                            <%= user.userId %>님 환영합니다.
                        </span>    
                    </li>
                    <li class="nav-item"><a href="/auth/logout" class="nav-link">로그아웃</a></li>                                
                    <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/auth/login">로그인</a></li>
                    <li class="nav-item"><a class="nav-link" href="/auth/register">회원가입</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <%- body %> 
    </div>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5>왕초뮤니티 (Wangcho Community)</h5>
                    <p class="mb-1">서울특별시 강남구 테헤란로 123, 왕초빌딩 5층</p>
                    <p class="mb-1">대표번호: 02-123-4567 | 이메일: help@wangcho.com</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-1">&copy; 2026 왕초뮤니티. All rights reserved.</p>
                    <p class="mb-0"><small>이용약관 | 개인정보처리방침</small></p>
                </div>
            </div>
        </div>
    </footer>

    <script src="/js/common.js"></script>
</body>

</html>